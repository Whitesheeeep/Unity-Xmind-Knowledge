        <mxCell id="P79LNxg_lGs8P4HROXfw-98" parent="P79LNxg_lGs8P4HROXfw-97" style="whiteSpace=wrap;html=1;strokeColor=default;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=default;fillColor=default;" value="生成行为请求：&lt;div&gt;Command 模式&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="30.5" y="119" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-99" edge="1" parent="P79LNxg_lGs8P4HROXfw-97" source="P79LNxg_lGs8P4HROXfw-96" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Helvetica;fontSize=12;fontColor=default;" target="P79LNxg_lGs8P4HROXfw-98" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-100" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="366.78" width="207" x="850.5" y="410" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-69" parent="P79LNxg_lGs8P4HROXfw-100" style="whiteSpace=wrap;html=1;rounded=0;fillColor=#e1d5e7;strokeColor=#9673a6;" value="" vertex="1">
          <mxGeometry height="366.78" width="207" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-72" parent="P79LNxg_lGs8P4HROXfw-100" style="whiteSpace=wrap;html=1;strokeColor=default;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=default;fillColor=default;" value="目标 Action CanEnter();" vertex="1">
          <mxGeometry height="60" width="166" x="20.5" y="18" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-75" parent="P79LNxg_lGs8P4HROXfw-100" style="whiteSpace=wrap;html=1;strokeColor=default;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=default;fillColor=default;" value="当前 Action CanBeInterrupted();" vertex="1">
          <mxGeometry height="60" width="166" x="20.5" y="103" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-79" parent="P79LNxg_lGs8P4HROXfw-100" style="whiteSpace=wrap;html=1;" value="执行切换" vertex="1">
          <mxGeometry height="52" width="168" x="19.5" y="192" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-78" edge="1" parent="P79LNxg_lGs8P4HROXfw-100" source="P79LNxg_lGs8P4HROXfw-72" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Helvetica;fontSize=12;fontColor=default;" target="P79LNxg_lGs8P4HROXfw-75" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-80" edge="1" parent="P79LNxg_lGs8P4HROXfw-100" source="P79LNxg_lGs8P4HROXfw-75" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Helvetica;fontSize=12;fontColor=default;" target="P79LNxg_lGs8P4HROXfw-79" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <UserObject label="&lt;p&gt;可以。那仲裁器就按：&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;strong&gt;本帧收集 Request → 排序 → 检查 → 执行最高优先级可用请求&lt;/strong&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;来设计。&lt;/p&gt;&lt;p&gt;下面写一个简化但结构完整的版本。&lt;/p&gt;&lt;h2&gt;1. Action 通道&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum ActionChannel&#xa;{&#xa;    UpperBody,&#xa;    FullBody&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;2. 打断请求类型&lt;/h2&gt;&lt;p&gt;用于描述请求的语义，不必依赖具体 Action 类型。&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum ActionRequestType&#xa;{&#xa;    Fire,&#xa;    Reload,&#xa;    Attack,&#xa;    Dodge,&#xa;    Skill,&#xa;    Hurt,&#xa;    Death&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;3. Action 接口&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public interface ICharacterAction&#xa;{&#xa;    ActionChannel Channel { get; }&#xa;&#xa;    bool CanEnter(CharacterContext context);&#xa;&#xa;    bool CanBeInterruptedBy(&#xa;        CharacterContext context,&#xa;        in ActionRequest request);&#xa;&#xa;    void Enter(CharacterContext context);&#xa;&#xa;    void Tick(CharacterContext context, float deltaTime);&#xa;&#xa;    void Exit(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;退出原因：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum ActionExitReason&#xa;{&#xa;    Completed,&#xa;    Interrupted,&#xa;    Cancelled,&#xa;    Death&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;4. ActionRequest&lt;/h2&gt;&lt;p&gt;Request 表示：&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;某个系统希望角色执行某个 Action。&lt;/p&gt;&lt;/blockquote&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public readonly struct ActionRequest&#xa;{&#xa;    public ICharacterAction Action { get; }&#xa;&#xa;    public ActionRequestType Type { get; }&#xa;&#xa;    public int Priority { get; }&#xa;&#xa;    public float BufferDuration { get; }&#xa;&#xa;    public ActionRequest(&#xa;        ICharacterAction action,&#xa;        ActionRequestType type,&#xa;        int priority,&#xa;        float bufferDuration = 0f)&#xa;    {&#xa;        Action = action;&#xa;        Type = type;&#xa;        Priority = priority;&#xa;        BufferDuration = bufferDuration;&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;例如：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Fire   Priority = 20&#xa;Attack Priority = 40&#xa;Dodge  Priority = 60&#xa;Hurt   Priority = 80&#xa;Death  Priority = 1000&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;5. ActionSlot&lt;/h2&gt;&lt;p&gt;Slot 只负责保存当前 Action 和执行生命周期。&lt;/p&gt;&lt;p&gt;它不负责从多个请求中选择。&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public sealed class ActionSlot&#xa;{&#xa;    public ICharacterAction Current { get; private set; }&#xa;&#xa;    public bool IsEmpty =&amp;gt; Current == null;&#xa;&#xa;    public void Change(&#xa;        ICharacterAction next,&#xa;        CharacterContext context)&#xa;    {&#xa;        Current?.Exit(&#xa;            context,&#xa;            ActionExitReason.Interrupted);&#xa;&#xa;        Current = next;&#xa;        Current.Enter(context);&#xa;    }&#xa;&#xa;    public void Complete(&#xa;        ICharacterAction action,&#xa;        CharacterContext context)&#xa;    {&#xa;        if (!ReferenceEquals(Current, action))&#xa;            return;&#xa;&#xa;        Current = null;&#xa;&#xa;        action.Exit(&#xa;            context,&#xa;            ActionExitReason.Completed);&#xa;    }&#xa;&#xa;    public void ForceClear(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason)&#xa;    {&#xa;        if (Current == null)&#xa;            return;&#xa;&#xa;        ICharacterAction old = Current;&#xa;        Current = null;&#xa;&#xa;        old.Exit(context, reason);&#xa;    }&#xa;&#xa;    public void Tick(&#xa;        CharacterContext context,&#xa;        float deltaTime)&#xa;    {&#xa;        Current?.Tick(context, deltaTime);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;6. PendingRequest&lt;/h1&gt;&lt;p&gt;仲裁器除了保存 Request，还要保存：&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;提交时间；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;提交顺序；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;缓冲过期时间。&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;internal readonly struct PendingActionRequest&#xa;{&#xa;    public ActionRequest Request { get; }&#xa;&#xa;    public float SubmitTime { get; }&#xa;&#xa;    public long Sequence { get; }&#xa;&#xa;    public PendingActionRequest(&#xa;        in ActionRequest request,&#xa;        float submitTime,&#xa;        long sequence)&#xa;    {&#xa;        Request = request;&#xa;        SubmitTime = submitTime;&#xa;        Sequence = sequence;&#xa;    }&#xa;&#xa;    public bool IsExpired(float currentTime)&#xa;    {&#xa;        if (Request.BufferDuration &amp;lt;= 0f)&#xa;            return false;&#xa;&#xa;        return currentTime &amp;gt;&#xa;               SubmitTime +&#xa;               Request.BufferDuration;&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;7. ActionArbiter&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;using System;&#xa;using System.Collections.Generic;&#xa;&#xa;public sealed class ActionArbiter&#xa;{&#xa;    private readonly CharacterContext _context;&#xa;&#xa;    private readonly ActionSlot _upperBody;&#xa;    private readonly ActionSlot _fullBody;&#xa;&#xa;    private readonly List&amp;lt;PendingActionRequest&amp;gt; _requests = new();&#xa;&#xa;    private long _sequence;&#xa;&#xa;    public ActionArbiter(&#xa;        CharacterContext context,&#xa;        ActionSlot upperBody,&#xa;        ActionSlot fullBody)&#xa;    {&#xa;        _context = context ??&#xa;                   throw new ArgumentNullException(nameof(context));&#xa;&#xa;        _upperBody = upperBody ??&#xa;                     throw new ArgumentNullException(nameof(upperBody));&#xa;&#xa;        _fullBody = fullBody ??&#xa;                    throw new ArgumentNullException(nameof(fullBody));&#xa;    }&#xa;&#xa;    public void Submit(&#xa;        in ActionRequest request,&#xa;        float currentTime)&#xa;    {&#xa;        if (request.Action == null)&#xa;            return;&#xa;&#xa;        _requests.Add(&#xa;            new PendingActionRequest(&#xa;                request,&#xa;                currentTime,&#xa;                _sequence++));&#xa;    }&#xa;&#xa;    public bool Resolve(float currentTime)&#xa;    {&#xa;        RemoveExpiredRequests(currentTime);&#xa;&#xa;        if (_requests.Count == 0)&#xa;            return false;&#xa;&#xa;        _requests.Sort(CompareRequest);&#xa;&#xa;        for (int i = 0; i &amp;lt; _requests.Count; i++)&#xa;        {&#xa;            PendingActionRequest pending = _requests[i];&#xa;&#xa;            if (!CanExecute(pending.Request))&#xa;                continue;&#xa;&#xa;            Execute(pending.Request);&#xa;&#xa;            _requests.RemoveAt(i);&#xa;&#xa;            // 第一版每帧只执行一个请求。&#xa;            RemoveUnbufferedRequests();&#xa;&#xa;            return true;&#xa;        }&#xa;&#xa;        // 当前帧没有请求成功。&#xa;        // 没有缓冲时间的请求直接丢弃。&#xa;        RemoveUnbufferedRequests();&#xa;&#xa;        return false;&#xa;    }&#xa;&#xa;    private bool CanExecute(in ActionRequest request)&#xa;    {&#xa;        ICharacterAction target = request.Action;&#xa;&#xa;        // 1. 目标 Action 自己判断能否进入。&#xa;        if (!target.CanEnter(_context))&#xa;            return false;&#xa;&#xa;        ActionSlot slot = GetSlot(target.Channel);&#xa;&#xa;        ICharacterAction current = slot.Current;&#xa;&#xa;        // 当前为空，可以直接进入。&#xa;        if (current == null)&#xa;            return true;&#xa;&#xa;        // 避免重复进入同一个实例。&#xa;        if (ReferenceEquals(current, target))&#xa;            return false;&#xa;&#xa;        // 2. 当前 Action 判断是否允许被请求打断。&#xa;        return current.CanBeInterruptedBy(&#xa;            _context,&#xa;            request);&#xa;    }&#xa;&#xa;    private void Execute(in ActionRequest request)&#xa;    {&#xa;        ActionSlot slot =&#xa;            GetSlot(request.Action.Channel);&#xa;&#xa;        slot.Change(&#xa;            request.Action,&#xa;            _context);&#xa;    }&#xa;&#xa;    private ActionSlot GetSlot(ActionChannel channel)&#xa;    {&#xa;        return channel switch&#xa;        {&#xa;            ActionChannel.UpperBody =&amp;gt; _upperBody,&#xa;            ActionChannel.FullBody =&amp;gt; _fullBody,&#xa;&#xa;            _ =&amp;gt; throw new ArgumentOutOfRangeException(&#xa;                nameof(channel),&#xa;                channel,&#xa;                null)&#xa;        };&#xa;    }&#xa;&#xa;    private void RemoveExpiredRequests(float currentTime)&#xa;    {&#xa;        for (int i = _requests.Count - 1; i &amp;gt;= 0; i--)&#xa;        {&#xa;            if (_requests[i].IsExpired(currentTime))&#xa;                _requests.RemoveAt(i);&#xa;        }&#xa;    }&#xa;&#xa;    private void RemoveUnbufferedRequests()&#xa;    {&#xa;        for (int i = _requests.Count - 1; i &amp;gt;= 0; i--)&#xa;        {&#xa;            if (_requests[i].Request.BufferDuration &amp;lt;= 0f)&#xa;                _requests.RemoveAt(i);&#xa;        }&#xa;    }&#xa;&#xa;    private static int CompareRequest(&#xa;        PendingActionRequest left,&#xa;        PendingActionRequest right)&#xa;    {&#xa;        // 优先级越高，越先处理。&#xa;        int priorityResult =&#xa;            right.Request.Priority.CompareTo(&#xa;                left.Request.Priority);&#xa;&#xa;        if (priorityResult != 0)&#xa;            return priorityResult;&#xa;&#xa;        // 同优先级时，先提交的先处理。&#xa;        return left.Sequence.CompareTo(right.Sequence);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;8. 剑攻击 Action&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum AttackPhase&#xa;{&#xa;    Startup,&#xa;    Active,&#xa;    Recovery&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public sealed class SwordAttackAction : ICharacterAction&#xa;{&#xa;    public ActionChannel Channel =&amp;gt;&#xa;        ActionChannel.FullBody;&#xa;&#xa;    public AttackPhase Phase { get; private set; }&#xa;&#xa;    public bool CanEnter(CharacterContext context)&#xa;    {&#xa;        return context.IsAlive &amp;amp;&amp;amp;&#xa;               context.IsGrounded &amp;amp;&amp;amp;&#xa;               context.Stamina &amp;gt;= 20;&#xa;    }&#xa;&#xa;    public bool CanBeInterruptedBy(&#xa;        CharacterContext context,&#xa;        in ActionRequest request)&#xa;    {&#xa;        if (request.Type == ActionRequestType.Death)&#xa;            return true;&#xa;&#xa;        if (request.Type == ActionRequestType.Hurt)&#xa;            return !context.HasSuperArmor;&#xa;&#xa;        if (request.Type == ActionRequestType.Dodge)&#xa;        {&#xa;            return Phase is AttackPhase.Startup&#xa;                or AttackPhase.Recovery;&#xa;        }&#xa;&#xa;        return false;&#xa;    }&#xa;&#xa;    public void Enter(CharacterContext context)&#xa;    {&#xa;        Phase = AttackPhase.Startup;&#xa;&#xa;        context.Stamina -= 20;&#xa;&#xa;        context.Animation.PlaySwordAttack(&#xa;            onActiveBegin: () =&amp;gt;&#xa;            {&#xa;                Phase = AttackPhase.Active;&#xa;                context.Combat.EnableSwordHitbox();&#xa;            },&#xa;            onRecoveryBegin: () =&amp;gt;&#xa;            {&#xa;                Phase = AttackPhase.Recovery;&#xa;                context.Combat.DisableSwordHitbox();&#xa;            },&#xa;            onEnd: () =&amp;gt;&#xa;            {&#xa;                context.FullBodySlot.Complete(&#xa;                    this,&#xa;                    context);&#xa;            });&#xa;    }&#xa;&#xa;    public void Tick(&#xa;        CharacterContext context,&#xa;        float deltaTime)&#xa;    {&#xa;    }&#xa;&#xa;    public void Exit(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason)&#xa;    {&#xa;        context.Combat.DisableSwordHitbox();&#xa;        context.Animation.StopFullBodyAction(this);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;9. Dodge Action&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public sealed class DodgeAction : ICharacterAction&#xa;{&#xa;    public ActionChannel Channel =&amp;gt;&#xa;        ActionChannel.FullBody;&#xa;&#xa;    public bool CanEnter(CharacterContext context)&#xa;    {&#xa;        return context.IsAlive &amp;amp;&amp;amp;&#xa;               context.IsGrounded &amp;amp;&amp;amp;&#xa;               context.Stamina &amp;gt;= 15;&#xa;    }&#xa;&#xa;    public bool CanBeInterruptedBy(&#xa;        CharacterContext context,&#xa;        in ActionRequest request)&#xa;    {&#xa;        // 闪避过程中通常只允许死亡强制打断。&#xa;        return request.Type ==&#xa;               ActionRequestType.Death;&#xa;    }&#xa;&#xa;    public void Enter(CharacterContext context)&#xa;    {&#xa;        context.Stamina -= 15;&#xa;&#xa;        context.Invincible = true;&#xa;&#xa;        context.Animation.PlayDodge(&#xa;            onEnd: () =&amp;gt;&#xa;            {&#xa;                context.FullBodySlot.Complete(&#xa;                    this,&#xa;                    context);&#xa;            });&#xa;    }&#xa;&#xa;    public void Tick(&#xa;        CharacterContext context,&#xa;        float deltaTime)&#xa;    {&#xa;    }&#xa;&#xa;    public void Exit(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason)&#xa;    {&#xa;        context.Invincible = false;&#xa;        context.Animation.StopFullBodyAction(this);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;10. 提交请求&lt;/h1&gt;&lt;p&gt;攻击输入：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnAttackPressed()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _swordAttack,&#xa;            ActionRequestType.Attack,&#xa;            priority: 40,&#xa;            bufferDuration: 0.15f),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;闪避输入：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnDodgePressed()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _dodge,&#xa;            ActionRequestType.Dodge,&#xa;            priority: 60,&#xa;            bufferDuration: 0.2f),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;受击：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnHurt()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _hurtAction,&#xa;            ActionRequestType.Hurt,&#xa;            priority: 80),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;死亡：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnDeath()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _deathAction,&#xa;            ActionRequestType.Death,&#xa;            priority: 1000),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;11. 每帧执行顺序&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;private void Update()&#xa;{&#xa;    float deltaTime = Time.deltaTime;&#xa;&#xa;    // 1. 采集输入，提交 Request。&#xa;    CollectInputRequests();&#xa;&#xa;    // 2. 仲裁本帧请求。&#xa;    _arbiter.Resolve(Time.time);&#xa;&#xa;    // 3. 更新状态和动作。&#xa;    _locomotion.Tick(deltaTime);&#xa;    _upperBodySlot.Tick(_context, deltaTime);&#xa;    _fullBodySlot.Tick(_context, deltaTime);&#xa;&#xa;    // 4. 最终运动处理。&#xa;    _motionDriver.Tick(deltaTime);&#xa;&#xa;    // 5. 连续动画参数。&#xa;    _animationController.Tick(deltaTime);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;12. 同一帧多个 Request&lt;/h1&gt;&lt;p&gt;假设同一帧提交：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Attack：40&#xa;Dodge：60&#xa;Hurt：80&#xa;Death：1000&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;排序后：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Death&#xa;Hurt&#xa;Dodge&#xa;Attack&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;仲裁器从高到低尝试。&lt;/p&gt;&lt;p&gt;如果死亡能进入：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;直接执行 Death&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;如果死亡不能进入，则继续检查 Hurt。&lt;/p&gt;&lt;p&gt;不过死亡这种请求一般应该始终能进入。&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;13. 被拒绝的请求怎么处理&lt;/h1&gt;&lt;p&gt;例如当前剑攻击处于 &lt;code&gt;Active&lt;/code&gt;：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Dodge Request&#xa;BufferDuration = 0.2 秒&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;此时：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;SwordAttack.CanBeInterruptedBy(Dodge)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;返回 &lt;code&gt;false&lt;/code&gt;。&lt;/p&gt;&lt;p&gt;请求不会马上删除，因为它有缓冲时间。&lt;/p&gt;&lt;p&gt;下一帧攻击进入 &lt;code&gt;Recovery&lt;/code&gt;：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Dodge Request 仍然存在&#xa;    ↓&#xa;重新仲裁&#xa;    ↓&#xa;允许&#xa;    ↓&#xa;Attack.Exit(Interrupted)&#xa;    ↓&#xa;Dodge.Enter()&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;这就是输入缓冲。&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;14. 第一版建议限制&lt;/h1&gt;&lt;p&gt;你现在可以先规定：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;每帧只成功执行一个 Request&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;这样最容易保证：&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;状态切换顺序稳定；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;不会同一帧连续切换多次；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;不会出现 Attack → Dodge → Hurt 三次 Enter/Exit；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;动画和约束不会反复抖动。&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;以后确实需要同时处理不同通道时，再扩展为：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;每个 Channel 每帧最多执行一个 Request&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;例如同一帧：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;UpperBody = Fire&#xa;FullBody = Empty&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;理论上可以同时执行两个不同通道请求，但第一版没有必要急着做。&lt;/p&gt;" link="&lt;p&gt;可以。那仲裁器就按：&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;strong&gt;本帧收集 Request → 排序 → 检查 → 执行最高优先级可用请求&lt;/strong&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;来设计。&lt;/p&gt;&lt;p&gt;下面写一个简化但结构完整的版本。&lt;/p&gt;&lt;h2&gt;1. Action 通道&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum ActionChannel&#xa;{&#xa;    UpperBody,&#xa;    FullBody&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;2. 打断请求类型&lt;/h2&gt;&lt;p&gt;用于描述请求的语义，不必依赖具体 Action 类型。&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum ActionRequestType&#xa;{&#xa;    Fire,&#xa;    Reload,&#xa;    Attack,&#xa;    Dodge,&#xa;    Skill,&#xa;    Hurt,&#xa;    Death&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;3. Action 接口&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public interface ICharacterAction&#xa;{&#xa;    ActionChannel Channel { get; }&#xa;&#xa;    bool CanEnter(CharacterContext context);&#xa;&#xa;    bool CanBeInterruptedBy(&#xa;        CharacterContext context,&#xa;        in ActionRequest request);&#xa;&#xa;    void Enter(CharacterContext context);&#xa;&#xa;    void Tick(CharacterContext context, float deltaTime);&#xa;&#xa;    void Exit(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;退出原因：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum ActionExitReason&#xa;{&#xa;    Completed,&#xa;    Interrupted,&#xa;    Cancelled,&#xa;    Death&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;4. ActionRequest&lt;/h2&gt;&lt;p&gt;Request 表示：&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;某个系统希望角色执行某个 Action。&lt;/p&gt;&lt;/blockquote&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public readonly struct ActionRequest&#xa;{&#xa;    public ICharacterAction Action { get; }&#xa;&#xa;    public ActionRequestType Type { get; }&#xa;&#xa;    public int Priority { get; }&#xa;&#xa;    public float BufferDuration { get; }&#xa;&#xa;    public ActionRequest(&#xa;        ICharacterAction action,&#xa;        ActionRequestType type,&#xa;        int priority,&#xa;        float bufferDuration = 0f)&#xa;    {&#xa;        Action = action;&#xa;        Type = type;&#xa;        Priority = priority;&#xa;        BufferDuration = bufferDuration;&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;例如：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Fire   Priority = 20&#xa;Attack Priority = 40&#xa;Dodge  Priority = 60&#xa;Hurt   Priority = 80&#xa;Death  Priority = 1000&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;5. ActionSlot&lt;/h2&gt;&lt;p&gt;Slot 只负责保存当前 Action 和执行生命周期。&lt;/p&gt;&lt;p&gt;它不负责从多个请求中选择。&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public sealed class ActionSlot&#xa;{&#xa;    public ICharacterAction Current { get; private set; }&#xa;&#xa;    public bool IsEmpty =&amp;gt; Current == null;&#xa;&#xa;    public void Change(&#xa;        ICharacterAction next,&#xa;        CharacterContext context)&#xa;    {&#xa;        Current?.Exit(&#xa;            context,&#xa;            ActionExitReason.Interrupted);&#xa;&#xa;        Current = next;&#xa;        Current.Enter(context);&#xa;    }&#xa;&#xa;    public void Complete(&#xa;        ICharacterAction action,&#xa;        CharacterContext context)&#xa;    {&#xa;        if (!ReferenceEquals(Current, action))&#xa;            return;&#xa;&#xa;        Current = null;&#xa;&#xa;        action.Exit(&#xa;            context,&#xa;            ActionExitReason.Completed);&#xa;    }&#xa;&#xa;    public void ForceClear(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason)&#xa;    {&#xa;        if (Current == null)&#xa;            return;&#xa;&#xa;        ICharacterAction old = Current;&#xa;        Current = null;&#xa;&#xa;        old.Exit(context, reason);&#xa;    }&#xa;&#xa;    public void Tick(&#xa;        CharacterContext context,&#xa;        float deltaTime)&#xa;    {&#xa;        Current?.Tick(context, deltaTime);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;6. PendingRequest&lt;/h1&gt;&lt;p&gt;仲裁器除了保存 Request，还要保存：&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;提交时间；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;提交顺序；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;缓冲过期时间。&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;internal readonly struct PendingActionRequest&#xa;{&#xa;    public ActionRequest Request { get; }&#xa;&#xa;    public float SubmitTime { get; }&#xa;&#xa;    public long Sequence { get; }&#xa;&#xa;    public PendingActionRequest(&#xa;        in ActionRequest request,&#xa;        float submitTime,&#xa;        long sequence)&#xa;    {&#xa;        Request = request;&#xa;        SubmitTime = submitTime;&#xa;        Sequence = sequence;&#xa;    }&#xa;&#xa;    public bool IsExpired(float currentTime)&#xa;    {&#xa;        if (Request.BufferDuration &amp;lt;= 0f)&#xa;            return false;&#xa;&#xa;        return currentTime &amp;gt;&#xa;               SubmitTime +&#xa;               Request.BufferDuration;&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;7. ActionArbiter&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;using System;&#xa;using System.Collections.Generic;&#xa;&#xa;public sealed class ActionArbiter&#xa;{&#xa;    private readonly CharacterContext _context;&#xa;&#xa;    private readonly ActionSlot _upperBody;&#xa;    private readonly ActionSlot _fullBody;&#xa;&#xa;    private readonly List&amp;lt;PendingActionRequest&amp;gt; _requests = new();&#xa;&#xa;    private long _sequence;&#xa;&#xa;    public ActionArbiter(&#xa;        CharacterContext context,&#xa;        ActionSlot upperBody,&#xa;        ActionSlot fullBody)&#xa;    {&#xa;        _context = context ??&#xa;                   throw new ArgumentNullException(nameof(context));&#xa;&#xa;        _upperBody = upperBody ??&#xa;                     throw new ArgumentNullException(nameof(upperBody));&#xa;&#xa;        _fullBody = fullBody ??&#xa;                    throw new ArgumentNullException(nameof(fullBody));&#xa;    }&#xa;&#xa;    public void Submit(&#xa;        in ActionRequest request,&#xa;        float currentTime)&#xa;    {&#xa;        if (request.Action == null)&#xa;            return;&#xa;&#xa;        _requests.Add(&#xa;            new PendingActionRequest(&#xa;                request,&#xa;                currentTime,&#xa;                _sequence++));&#xa;    }&#xa;&#xa;    public bool Resolve(float currentTime)&#xa;    {&#xa;        RemoveExpiredRequests(currentTime);&#xa;&#xa;        if (_requests.Count == 0)&#xa;            return false;&#xa;&#xa;        _requests.Sort(CompareRequest);&#xa;&#xa;        for (int i = 0; i &amp;lt; _requests.Count; i++)&#xa;        {&#xa;            PendingActionRequest pending = _requests[i];&#xa;&#xa;            if (!CanExecute(pending.Request))&#xa;                continue;&#xa;&#xa;            Execute(pending.Request);&#xa;&#xa;            _requests.RemoveAt(i);&#xa;&#xa;            // 第一版每帧只执行一个请求。&#xa;            RemoveUnbufferedRequests();&#xa;&#xa;            return true;&#xa;        }&#xa;&#xa;        // 当前帧没有请求成功。&#xa;        // 没有缓冲时间的请求直接丢弃。&#xa;        RemoveUnbufferedRequests();&#xa;&#xa;        return false;&#xa;    }&#xa;&#xa;    private bool CanExecute(in ActionRequest request)&#xa;    {&#xa;        ICharacterAction target = request.Action;&#xa;&#xa;        // 1. 目标 Action 自己判断能否进入。&#xa;        if (!target.CanEnter(_context))&#xa;            return false;&#xa;&#xa;        ActionSlot slot = GetSlot(target.Channel);&#xa;&#xa;        ICharacterAction current = slot.Current;&#xa;&#xa;        // 当前为空，可以直接进入。&#xa;        if (current == null)&#xa;            return true;&#xa;&#xa;        // 避免重复进入同一个实例。&#xa;        if (ReferenceEquals(current, target))&#xa;            return false;&#xa;&#xa;        // 2. 当前 Action 判断是否允许被请求打断。&#xa;        return current.CanBeInterruptedBy(&#xa;            _context,&#xa;            request);&#xa;    }&#xa;&#xa;    private void Execute(in ActionRequest request)&#xa;    {&#xa;        ActionSlot slot =&#xa;            GetSlot(request.Action.Channel);&#xa;&#xa;        slot.Change(&#xa;            request.Action,&#xa;            _context);&#xa;    }&#xa;&#xa;    private ActionSlot GetSlot(ActionChannel channel)&#xa;    {&#xa;        return channel switch&#xa;        {&#xa;            ActionChannel.UpperBody =&amp;gt; _upperBody,&#xa;            ActionChannel.FullBody =&amp;gt; _fullBody,&#xa;&#xa;            _ =&amp;gt; throw new ArgumentOutOfRangeException(&#xa;                nameof(channel),&#xa;                channel,&#xa;                null)&#xa;        };&#xa;    }&#xa;&#xa;    private void RemoveExpiredRequests(float currentTime)&#xa;    {&#xa;        for (int i = _requests.Count - 1; i &amp;gt;= 0; i--)&#xa;        {&#xa;            if (_requests[i].IsExpired(currentTime))&#xa;                _requests.RemoveAt(i);&#xa;        }&#xa;    }&#xa;&#xa;    private void RemoveUnbufferedRequests()&#xa;    {&#xa;        for (int i = _requests.Count - 1; i &amp;gt;= 0; i--)&#xa;        {&#xa;            if (_requests[i].Request.BufferDuration &amp;lt;= 0f)&#xa;                _requests.RemoveAt(i);&#xa;        }&#xa;    }&#xa;&#xa;    private static int CompareRequest(&#xa;        PendingActionRequest left,&#xa;        PendingActionRequest right)&#xa;    {&#xa;        // 优先级越高，越先处理。&#xa;        int priorityResult =&#xa;            right.Request.Priority.CompareTo(&#xa;                left.Request.Priority);&#xa;&#xa;        if (priorityResult != 0)&#xa;            return priorityResult;&#xa;&#xa;        // 同优先级时，先提交的先处理。&#xa;        return left.Sequence.CompareTo(right.Sequence);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;8. 剑攻击 Action&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public enum AttackPhase&#xa;{&#xa;    Startup,&#xa;    Active,&#xa;    Recovery&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public sealed class SwordAttackAction : ICharacterAction&#xa;{&#xa;    public ActionChannel Channel =&amp;gt;&#xa;        ActionChannel.FullBody;&#xa;&#xa;    public AttackPhase Phase { get; private set; }&#xa;&#xa;    public bool CanEnter(CharacterContext context)&#xa;    {&#xa;        return context.IsAlive &amp;amp;&amp;amp;&#xa;               context.IsGrounded &amp;amp;&amp;amp;&#xa;               context.Stamina &amp;gt;= 20;&#xa;    }&#xa;&#xa;    public bool CanBeInterruptedBy(&#xa;        CharacterContext context,&#xa;        in ActionRequest request)&#xa;    {&#xa;        if (request.Type == ActionRequestType.Death)&#xa;            return true;&#xa;&#xa;        if (request.Type == ActionRequestType.Hurt)&#xa;            return !context.HasSuperArmor;&#xa;&#xa;        if (request.Type == ActionRequestType.Dodge)&#xa;        {&#xa;            return Phase is AttackPhase.Startup&#xa;                or AttackPhase.Recovery;&#xa;        }&#xa;&#xa;        return false;&#xa;    }&#xa;&#xa;    public void Enter(CharacterContext context)&#xa;    {&#xa;        Phase = AttackPhase.Startup;&#xa;&#xa;        context.Stamina -= 20;&#xa;&#xa;        context.Animation.PlaySwordAttack(&#xa;            onActiveBegin: () =&amp;gt;&#xa;            {&#xa;                Phase = AttackPhase.Active;&#xa;                context.Combat.EnableSwordHitbox();&#xa;            },&#xa;            onRecoveryBegin: () =&amp;gt;&#xa;            {&#xa;                Phase = AttackPhase.Recovery;&#xa;                context.Combat.DisableSwordHitbox();&#xa;            },&#xa;            onEnd: () =&amp;gt;&#xa;            {&#xa;                context.FullBodySlot.Complete(&#xa;                    this,&#xa;                    context);&#xa;            });&#xa;    }&#xa;&#xa;    public void Tick(&#xa;        CharacterContext context,&#xa;        float deltaTime)&#xa;    {&#xa;    }&#xa;&#xa;    public void Exit(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason)&#xa;    {&#xa;        context.Combat.DisableSwordHitbox();&#xa;        context.Animation.StopFullBodyAction(this);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;9. Dodge Action&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public sealed class DodgeAction : ICharacterAction&#xa;{&#xa;    public ActionChannel Channel =&amp;gt;&#xa;        ActionChannel.FullBody;&#xa;&#xa;    public bool CanEnter(CharacterContext context)&#xa;    {&#xa;        return context.IsAlive &amp;amp;&amp;amp;&#xa;               context.IsGrounded &amp;amp;&amp;amp;&#xa;               context.Stamina &amp;gt;= 15;&#xa;    }&#xa;&#xa;    public bool CanBeInterruptedBy(&#xa;        CharacterContext context,&#xa;        in ActionRequest request)&#xa;    {&#xa;        // 闪避过程中通常只允许死亡强制打断。&#xa;        return request.Type ==&#xa;               ActionRequestType.Death;&#xa;    }&#xa;&#xa;    public void Enter(CharacterContext context)&#xa;    {&#xa;        context.Stamina -= 15;&#xa;&#xa;        context.Invincible = true;&#xa;&#xa;        context.Animation.PlayDodge(&#xa;            onEnd: () =&amp;gt;&#xa;            {&#xa;                context.FullBodySlot.Complete(&#xa;                    this,&#xa;                    context);&#xa;            });&#xa;    }&#xa;&#xa;    public void Tick(&#xa;        CharacterContext context,&#xa;        float deltaTime)&#xa;    {&#xa;    }&#xa;&#xa;    public void Exit(&#xa;        CharacterContext context,&#xa;        ActionExitReason reason)&#xa;    {&#xa;        context.Invincible = false;&#xa;        context.Animation.StopFullBodyAction(this);&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;10. 提交请求&lt;/h1&gt;&lt;p&gt;攻击输入：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnAttackPressed()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _swordAttack,&#xa;            ActionRequestType.Attack,&#xa;            priority: 40,&#xa;            bufferDuration: 0.15f),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;闪避输入：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnDodgePressed()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _dodge,&#xa;            ActionRequestType.Dodge,&#xa;            priority: 60,&#xa;            bufferDuration: 0.2f),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;受击：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnHurt()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _hurtAction,&#xa;            ActionRequestType.Hurt,&#xa;            priority: 80),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;死亡：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;public void OnDeath()&#xa;{&#xa;    _arbiter.Submit(&#xa;        new ActionRequest(&#xa;            _deathAction,&#xa;            ActionRequestType.Death,&#xa;            priority: 1000),&#xa;        Time.time);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;11. 每帧执行顺序&lt;/h1&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;private void Update()&#xa;{&#xa;    float deltaTime = Time.deltaTime;&#xa;&#xa;    // 1. 采集输入，提交 Request。&#xa;    CollectInputRequests();&#xa;&#xa;    // 2. 仲裁本帧请求。&#xa;    _arbiter.Resolve(Time.time);&#xa;&#xa;    // 3. 更新状态和动作。&#xa;    _locomotion.Tick(deltaTime);&#xa;    _upperBodySlot.Tick(_context, deltaTime);&#xa;    _fullBodySlot.Tick(_context, deltaTime);&#xa;&#xa;    // 4. 最终运动处理。&#xa;    _motionDriver.Tick(deltaTime);&#xa;&#xa;    // 5. 连续动画参数。&#xa;    _animationController.Tick(deltaTime);&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;12. 同一帧多个 Request&lt;/h1&gt;&lt;p&gt;假设同一帧提交：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Attack：40&#xa;Dodge：60&#xa;Hurt：80&#xa;Death：1000&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;排序后：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Death&#xa;Hurt&#xa;Dodge&#xa;Attack&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;仲裁器从高到低尝试。&lt;/p&gt;&lt;p&gt;如果死亡能进入：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;直接执行 Death&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;如果死亡不能进入，则继续检查 Hurt。&lt;/p&gt;&lt;p&gt;不过死亡这种请求一般应该始终能进入。&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;13. 被拒绝的请求怎么处理&lt;/h1&gt;&lt;p&gt;例如当前剑攻击处于 &lt;code&gt;Active&lt;/code&gt;：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Dodge Request&#xa;BufferDuration = 0.2 秒&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;此时：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-csharp&quot;&gt;SwordAttack.CanBeInterruptedBy(Dodge)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;返回 &lt;code&gt;false&lt;/code&gt;。&lt;/p&gt;&lt;p&gt;请求不会马上删除，因为它有缓冲时间。&lt;/p&gt;&lt;p&gt;下一帧攻击进入 &lt;code&gt;Recovery&lt;/code&gt;：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Dodge Request 仍然存在&#xa;    ↓&#xa;重新仲裁&#xa;    ↓&#xa;允许&#xa;    ↓&#xa;Attack.Exit(Interrupted)&#xa;    ↓&#xa;Dodge.Enter()&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;这就是输入缓冲。&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;14. 第一版建议限制&lt;/h1&gt;&lt;p&gt;你现在可以先规定：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;每帧只成功执行一个 Request&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;这样最容易保证：&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;状态切换顺序稳定；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;不会同一帧连续切换多次；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;不会出现 Attack → Dodge → Hurt 三次 Enter/Exit；&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;动画和约束不会反复抖动。&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;以后确实需要同时处理不同通道时，再扩展为：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;每个 Channel 每帧最多执行一个 Request&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;例如同一帧：&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;UpperBody = Fire&#xa;FullBody = Empty&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;理论上可以同时执行两个不同通道请求，但第一版没有必要急着做。&lt;/p&gt;" id="P79LNxg_lGs8P4HROXfw-105">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=default;" vertex="1">
            <mxGeometry height="9690" width="489" x="1328.0030766296386" y="21.995347055288562" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="P79LNxg_lGs8P4HROXfw-110" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="280" width="370" x="-330" y="630" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-83" parent="P79LNxg_lGs8P4HROXfw-110" style="whiteSpace=wrap;html=1;rounded=0;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;黑板：&lt;br&gt;1. 基本移动数据：移动方向等等&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;2. Player 各类数据&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="370" as="geometry" />
        </mxCell>
        <mxCell id="P79LNxg_lGs8P4HROXfw-109" parent="P79LNxg_lGs8P4HROXfw-110" style="whiteSpace=wrap;html=1;rounded=0;align=left;verticalAlign=top;" value="MovementConstriait：用于限制 Motion 驱动的数据" vertex="1">
          <mxGeometry height="70" width="340" x="20" y="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
